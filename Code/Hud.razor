@using Sandbox;
@using Sandbox.UI;
@using System;
@inherits PanelComponent

<root>
    <div class="hud-container">
        <label class="title">movement telemetry</label>
        
        @if (PlayerTracker == null)
        {
            <label class="error">movement component not linked</label>
        }
        else
        {
            <div class="row">
                <span class="label">State:</span>
                <span class="value">@PlayerTracker.CurrentState?.GetType().Name</span>
            </div>

            <div class="row">
                <span class="label">Absolute SPD:</span>
                <span class="value">@(MathF.Round(AbsSpeed))</span>
                <span class="peak">(Peak: @(MathF.Round(PeakAbs.Value)))</span>
            </div>

            <div class="row">
                <span class="label">Forward (X):</span>
                <span class="value">@(MathF.Round(RelativeVel.x))</span>
                <span class="peak">(Peak: @(MathF.Round(PeakX.Value)))</span>
            </div>

            <div class="row">
                <span class="label">Lateral (Y):</span>
                <span class="value">@(MathF.Round(RelativeVel.y))</span>
                <span class="peak">(Peak: @(MathF.Round(PeakY.Value)))</span>
            </div>
            
            <div class="row">
                <span class="label">Vertical (Z):</span>
                <span class="value">@(MathF.Round(RelativeVel.z))</span>
                <span class="peak">(Peak: @(MathF.Round(PeakZ.Value)))</span>
            </div>

            <div class="row">
                <span class="label">Coyote Active:</span>
                <span class="value @(CoyoteActive ? "coyote-active" : "")">
                    @CoyoteActive
                </span>
            </div>

            <div class="row">
                <span class="label">Coyote Timer:</span>
                <span class="value">@(MathF.Round((float)PlayerTracker.TimeSinceLeftWall, 2))</span>
            </div>

            <div class="row">
                <span class="label">HasWallJumped:</span>
                <span class="value">@PlayerTracker.HasWallJumped</span>
            </div>

            <div class="row">
                <span class="label">Stamina:</span>
                <span class="value">@(MathF.Round(PlayerTracker.Stamina.Charges, 2))</span>
            </div>

        }
    </div>

    @if (PlayerTracker != null)
    {
        bool flashing = (float)PlayerTracker.Stamina.TimeSinceLastFailedConsume < 0.4f;
        int fullPips = (int)MathF.Floor( PlayerTracker.Stamina.Charges );
        bool dashWindow = (PlayerTracker.CurrentState as DashState)?.IsInDashJumpWindow ?? false;

        <div class="crosshair-container">
            <div class="crosshair-dot"></div>
            <div class="stamina-pips">
                <div class="pip @(dashWindow ? "pip-dash-window" : fullPips >= 1 ? "pip-full" : flashing ? "pip-flash" : "pip-empty")"></div>
                <div class="pip @(dashWindow ? "pip-dash-window" : fullPips >= 2 ? "pip-full" : flashing ? "pip-flash" : "pip-empty")"></div>
                <div class="pip @(dashWindow ? "pip-dash-window" : fullPips >= 3 ? "pip-full" : flashing ? "pip-flash" : "pip-empty")"></div>
            </div>
        </div>
    }
</root>

@code
{
    [Property] public global::Movement PlayerTracker { get; set; }

    public struct PeakTracker
    {
        public float Value;
        public float TimeSet;

        public void Update(float current)
        {
            // if our velocity is higher or 2 seconds have passed, update our peak velocity value
            if (MathF.Abs(current) > MathF.Abs(Value) || Time.Now - TimeSet > 2f)
            {
                Value = current;
                TimeSet = Time.Now;
            }
        }
    }

    private PeakTracker PeakAbs;
    private PeakTracker PeakX;
    private PeakTracker PeakY;
    private PeakTracker PeakZ;

    private float AbsSpeed;
    private Vector3 RelativeVel;

    private bool CoyoteActive => PlayerTracker.TimeSinceLeftWall < PlayerTracker.WallCoyoteTime;


    protected override void OnUpdate()
    {
        if (PlayerTracker == null || PlayerTracker.Controller == null) return;

        // calculate absolute velocity
        AbsSpeed = PlayerTracker.Controller.Velocity.Length;
        PeakAbs.Update(AbsSpeed);

        // making our x and y readings relative to the camera direction
        Rotation camYaw = Rotation.FromYaw(PlayerTracker.Scene.Camera.WorldRotation.Angles().yaw);
        RelativeVel = PlayerTracker.Controller.Velocity * camYaw.Inverse;

        PeakX.Update(RelativeVel.x);
        PeakY.Update(RelativeVel.y);
        PeakZ.Update(RelativeVel.z);
    }

    protected override int BuildHash()
    {
        // make ui update every frame
        return HashCode.Combine( Time.Now );
    }
}

<style>
    .hud-container {
        position: absolute;
        bottom: 50px;
        left: 50px;
        flex-direction: column;
        color: white;
        font-family: Consolas, monospace;
        font-size: 20px;
        text-shadow: 2px 2px 0px black;
        background-color: rgba(0, 0, 0, 0.4);
        padding: 15px;
        border-radius: 8px;
    }
    
    .title {
        font-size: 24px;
        font-weight: bold;
        color: #ffcc00;
        margin-bottom: 15px;
    }

    .error {
        color: #ff4444;
    }

    .row {
        margin-bottom: 5px;
        flex-direction: row;
        width: 450px;
    }

    .label {
        color: #cccccc;
        width: 175px;
    }

    .value {
        width: 100px;
        font-weight: bold;
    }

    .peak {
        color: #888888;
        font-size: 16px;
    }

    .coyote-active {
    color: #ffcc00;
    font-weight: bold;
    }

    .crosshair-container {
        position: absolute;
        left: 50%;
        top: 50%;
        margin-left: -20px;
        margin-top: -6px;
        flex-direction: column;
        align-items: center;
    }

    .crosshair-dot {
        width: 5px;
        height: 5px;
        border-radius: 3px;
        background-color: rgba(255, 255, 255, 0.85);
        margin-bottom: 6px;
    }

    .stamina-pips {
        flex-direction: row;
    }

    .pip {
        width: 9px;
        height: 9px;
        border-radius: 5px;
        margin: 2px;
    }

    .pip-full {
        background-color: rgba(255, 255, 255, 0.9);
    }

    .pip-empty {
        background-color: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.35);
    }

    .pip-flash {
        background-color: rgba(255, 70, 70, 0.95);
    }

    .pip-dash-window {
        background-color: rgba(80, 180, 255, 0.95);
    }

</style>
